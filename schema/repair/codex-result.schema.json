{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Projectclawsweeper worker result",
  "type": "object",
  "required": [
    "status",
    "repo",
    "cluster_id",
    "mode",
    "summary",
    "actions",
    "needs_human",
    "canonical",
    "canonical_issue",
    "canonical_pr",
    "merge_preflight",
    "fix_artifact"
  ],
  "additionalProperties": false,
  "properties": {
    "status": {
      "enum": ["planned", "needs_human", "blocked", "failed"]
    },
    "repo": {
      "type": "string"
    },
    "cluster_id": {
      "type": "string"
    },
    "mode": {
      "enum": ["plan", "execute", "autonomous"]
    },
    "summary": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target",
          "action",
          "status",
          "idempotency_key",
          "classification",
          "target_kind",
          "target_updated_at",
          "canonical",
          "duplicate_of",
          "candidate_fix",
          "comment",
          "evidence",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "target": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "keep_canonical",
              "keep_related",
              "keep_independent",
              "keep_closed",
              "merge_candidate",
              "merge_canonical",
              "fix_needed",
              "build_fix_artifact",
              "open_fix_pr",
              "post_merge_close",
              "route_security",
              "needs_human",
              "close",
              "close_duplicate",
              "close_superseded",
              "close_fixed_by_candidate",
              "close_low_signal",
              "label",
              "comment"
            ]
          },
          "status": {
            "enum": ["planned", "skipped", "blocked", "failed"]
          },
          "idempotency_key": {
            "type": "string"
          },
          "classification": {
            "type": ["string", "null"],
            "enum": [
              "canonical",
              "duplicate",
              "related",
              "superseded",
              "independent",
              "fixed_by_candidate",
              "low_signal",
              "security_sensitive",
              "needs_human",
              null
            ]
          },
          "target_kind": {
            "type": ["string", "null"],
            "enum": ["issue", "pull_request", null]
          },
          "target_updated_at": {
            "type": ["string", "null"]
          },
          "canonical": {
            "type": ["string", "null"],
            "pattern": "^#?[0-9]+$"
          },
          "duplicate_of": {
            "type": ["string", "null"],
            "pattern": "^#?[0-9]+$"
          },
          "candidate_fix": {
            "type": ["string", "null"],
            "pattern": "^#?[0-9]+$"
          },
          "comment": {
            "type": ["string", "null"]
          },
          "evidence": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "required": ["label", "detail", "file", "line", "command", "sha"],
                  "additionalProperties": false,
                  "properties": {
                    "label": {
                      "type": "string"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "file": {
                      "type": ["string", "null"]
                    },
                    "line": {
                      "type": ["integer", "null"]
                    },
                    "command": {
                      "type": ["string", "null"]
                    },
                    "sha": {
                      "type": ["string", "null"]
                    }
                  }
                }
              ]
            }
          },
          "reason": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "needs_human": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonical": {
      "type": ["string", "null"]
    },
    "canonical_issue": {
      "type": ["string", "null"]
    },
    "canonical_pr": {
      "type": ["string", "null"]
    },
    "merge_preflight": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target",
          "security_status",
          "security_evidence",
          "comments_status",
          "comments_evidence",
          "bot_comments_status",
          "bot_comments_evidence",
          "codex_review",
          "validation_commands"
        ],
        "additionalProperties": false,
        "properties": {
          "target": {
            "type": "string",
            "pattern": "^#?[0-9]+$"
          },
          "security_status": {
            "type": "string",
            "enum": ["cleared"]
          },
          "security_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "comments_status": {
            "type": "string",
            "enum": ["resolved"]
          },
          "comments_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bot_comments_status": {
            "type": "string",
            "enum": ["resolved"]
          },
          "bot_comments_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "codex_review": {
            "type": "object",
            "required": ["command", "status", "findings_addressed", "evidence"],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "string",
                "const": "/review"
              },
              "status": {
                "type": "string",
                "enum": ["passed", "clean"]
              },
              "findings_addressed": {
                "type": "boolean",
                "const": true
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "validation_commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "fix_artifact": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "summary",
            "affected_surfaces",
            "likely_files",
            "linked_refs",
            "validation_commands",
            "changelog_required",
            "credit_notes",
            "pr_title",
            "pr_body",
            "source_prs",
            "repair_strategy",
            "allow_no_pr",
            "branch_update_blockers",
            "repair_contract"
          ],
          "additionalProperties": false,
          "properties": {
            "summary": {
              "type": "string"
            },
            "affected_surfaces": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "likely_files": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "linked_refs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "validation_commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "changelog_required": {
              "type": "boolean"
            },
            "credit_notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pr_title": {
              "type": "string",
              "maxLength": 256
            },
            "pr_body": {
              "type": "string"
            },
            "source_prs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "repair_strategy": {
              "type": "string",
              "enum": [
                "repair_contributor_branch",
                "replace_uneditable_branch",
                "new_fix_pr",
                "already_fixed_on_main",
                "needs_human"
              ]
            },
            "allow_no_pr": {
              "type": "boolean"
            },
            "branch_update_blockers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "repair_contract": {
              "anyOf": [
                {
                  "type": "null"
                },
                {
                  "type": "object",
                  "required": ["must_touch", "match"],
                  "additionalProperties": false,
                  "properties": {
                    "must_touch": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string"
                      }
                    },
                    "match": {
                      "type": "string",
                      "enum": ["any", "all"]
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
